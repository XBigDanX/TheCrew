<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="root" alignment="CENTER" prefHeight="800.0" prefWidth="1500.0" spacing="30" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="game.thecrew.controllers.PlayerCountController">

   <Label text="Select number of players" style="-fx-font-size: 36; -fx-font-weight: bold;" />

   <Button fx:id="twoPlayersButton" text="2 Players" style="-fx-font-size: 18;" onAction="#onTwoPlayers" />

   <Button text="3 Players" style="-fx-font-size: 18;" onAction="#onThreePlayers" />

   <Button text="4 Players" style="-fx-font-size: 18;" onAction="#onFourPlayers" />

   <Button text="5 Players" style="-fx-font-size: 18;" onAction="#onFivePlayers" />

</VBox>
