<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="800.0" prefWidth="1500.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="game.thecrew.controllers.GameController">

  <!-- ========================= -->
  <!-- PLAYER HANDS -->
  <!-- ========================= -->

  <!-- ========================= -->
  <!-- GAME INFO BAR -->
  <!-- ========================= -->

  <Pane fx:id="topBar" layoutY="15.0" prefHeight="50.0" prefWidth="1503.0" style="-fx-background-color: lightgray; -fx-border-color: black;">

    <Label fx:id="missionLabel" layoutX="50.0" layoutY="17.0" text="Mission: 0" />

    <Label fx:id="difficultyLabel" layoutX="200.0" layoutY="17.0" text="Difficulty: ?" />

    <Label fx:id="missionDescriptionLabel" layoutX="320.0" layoutY="17.0" text="" />

    <Label fx:id="currentPlayerLabel" layoutX="884.0" layoutY="17.0" text="Current Player: 0" />

    <Button fx:id="passTaskSelectionButton" layoutX="1009.0" layoutY="13.0" prefWidth="120.0" text="Pass Tasks" />

    <!-- top-bar Communicate button is hidden for now; will be used in per-window view -->
    <Button fx:id="communicateButton" layoutX="800.0" layoutY="13.0" managed="false" prefWidth="120.0" text="Communicate" visible="false" />

    <Button fx:id="saveButton" layoutX="1200.0" layoutY="13.0" prefWidth="80.0" text="Save" />
    <Button fx:id="loadButton" layoutX="1290.0" layoutY="13.0" prefWidth="80.0" text="Load" />

  </Pane>

  <FlowPane fx:id="hand0" hgap="10" layoutX="43.0" layoutY="588.0" prefHeight="187.0" prefWidth="994.0" style="-fx-background-color: black;" vgap="10" />

  <FlowPane fx:id="hand1" hgap="10" layoutX="46.0" layoutY="69.0" prefHeight="176.0" prefWidth="994.0" style="-fx-background-color: black;" vgap="10" />

  <FlowPane fx:id="hand2" hgap="10" layoutX="825.0" layoutY="236.0" prefHeight="143.0" prefWidth="500.0" vgap="10" />

  <FlowPane fx:id="hand3" hgap="10" layoutX="879.0" layoutY="379.0" prefHeight="143.0" prefWidth="500.0" vgap="10" />

  <FlowPane fx:id="hand4" hgap="10" layoutX="796.0" layoutY="451.0" prefHeight="143.0" prefWidth="500.0" vgap="10" />

  <!-- ========================= -->
  <!-- TRICK PLAY LAYER -->
  <!-- ========================= -->

  <Pane fx:id="trickPane" layoutX="350.0" layoutY="250.0" managed="false" prefHeight="300" prefWidth="500" style="-fx-background-color: grey;">

    <Pane fx:id="slot1" layoutX="50.0" layoutY="21.0" prefHeight="120" prefWidth="80" style="-fx-background-color: transparent; -fx-border-color: black; -fx-border-style: dashed; -fx-border-width: 2;" />

    <Pane fx:id="slot2" layoutX="373.0" layoutY="21.0" prefHeight="120" prefWidth="80" style="-fx-background-color: transparent; -fx-border-color: black; -fx-border-style: dashed; -fx-border-width: 2;" />

    <Pane fx:id="slot3" layoutX="373.0" layoutY="160.0" prefHeight="120" prefWidth="80" style="-fx-background-color: transparent; -fx-border-color: black; -fx-border-style: dashed; -fx-border-width: 2;" />

    <Pane fx:id="slot4" layoutX="216.0" layoutY="21.0" prefHeight="120" prefWidth="80" style="-fx-background-color: transparent; -fx-border-color: black; -fx-border-style: dashed; -fx-border-width: 2;" />

    <Pane fx:id="slot0" layoutX="50.0" layoutY="160.0" prefHeight="120" prefWidth="80" style="-fx-background-color: transparent; -fx-border-color: black; -fx-border-style: dashed; -fx-border-width: 2;" />

  </Pane>

  <!-- ========================= -->
  <!-- TASK SELECTION LAYER -->
  <!-- ========================= -->

  <Pane fx:id="taskPane" layoutX="358.0" layoutY="250.0" prefHeight="300.0" prefWidth="500.0" style="-fx-background-color: grey;">

    <Label layoutX="177.0" layoutY="28.0" text="Available Tasks">
         <font>
            <Font size="22.0" />
         </font></Label>

    <HBox fx:id="availableTasksBox" layoutX="45.0" layoutY="95.0" prefHeight="110.0" prefWidth="410.0" spacing="10" />

  </Pane>

  <Label fx:id="infoLabel0" layoutX="43.0" layoutY="447.0" style="-fx-font-size: 11; -fx-background-color: rgba(0,0,0,0.1); -fx-padding: 2;" />
  <HBox fx:id="taskHand0" layoutX="43.0" layoutY="468.0" prefHeight="120.0" prefWidth="260.0" style="-fx-background-color: green;" />
  <StackPane fx:id="commArea0" layoutX="303.0" layoutY="468.0" prefHeight="120" prefWidth="80" style="-fx-background-color: lightgrey; -fx-border-color: darkgrey; -fx-border-width: 1;" />

  <Label fx:id="infoLabel1" layoutX="46.0" layoutY="365.0" style="-fx-font-size: 11; -fx-background-color: rgba(0,0,0,0.1); -fx-padding: 2;" />
  <HBox fx:id="taskHand1" layoutX="46.0" layoutY="245.0" prefHeight="120.0" prefWidth="260.0" style="-fx-background-color: green;" />
  <StackPane fx:id="commArea1" layoutX="306.0" layoutY="245.0" prefHeight="120" prefWidth="80" style="-fx-background-color: lightgrey; -fx-border-color: darkgrey; -fx-border-width: 1;" />

  <Label fx:id="infoLabel2" layoutX="983.0" layoutY="160.0" style="-fx-font-size: 11; -fx-background-color: rgba(0,0,0,0.1); -fx-padding: 2;" />
  <HBox fx:id="taskHand2" layoutX="983.0" layoutY="173.0" prefHeight="100.0" prefWidth="295.0" />
  <StackPane fx:id="commArea2" layoutX="878.0" layoutY="173.0" prefHeight="120" prefWidth="80" style="-fx-background-color: lightgrey; -fx-border-color: darkgrey; -fx-border-width: 1;" />

  <Label fx:id="infoLabel3" layoutX="1065.0" layoutY="531.0" style="-fx-font-size: 11; -fx-background-color: rgba(0,0,0,0.1); -fx-padding: 2;" />
  <HBox fx:id="taskHand3" layoutX="1065.0" layoutY="544.0" prefHeight="100.0" prefWidth="260.0" />
  <StackPane fx:id="commArea3" layoutX="1163.0" layoutY="405.0" prefHeight="120" prefWidth="80" style="-fx-background-color: lightgrey; -fx-border-color: darkgrey; -fx-border-width: 1;" />

  <Label fx:id="infoLabel4" layoutX="1065.0" layoutY="637.0" style="-fx-font-size: 11; -fx-background-color: rgba(0,0,0,0.1); -fx-padding: 2;" />
  <HBox fx:id="taskHand4" layoutX="1065.0" layoutY="650.0" prefHeight="100.0" prefWidth="260.0" />
  <StackPane fx:id="commArea4" layoutX="1068.0" layoutY="479.0" prefHeight="120" prefWidth="80" style="-fx-background-color: lightgrey; -fx-border-color: darkgrey; -fx-border-width: 1;" />

  <!-- ========================= -->
  <!-- MISSION RESULT OVERLAY -->
  <!-- ========================= -->

  <StackPane fx:id="missionResultOverlay" managed="false" visible="false" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">

    <!-- dark background covering whole screen -->
    <Pane style="-fx-background-color: rgba(0,0,0,0.5);" />

    <!-- centered dialog -->
    <VBox alignment="CENTER" maxHeight="250" maxWidth="400" spacing="20" style="-fx-background-color: white;                  -fx-border-color: black;                  -fx-border-width: 2;                  -fx-padding: 30;">

      <Label fx:id="resultTitleLabel" style="-fx-font-size: 28; -fx-font-weight: bold;" />

      <Label fx:id="resultMessageLabel" style="-fx-font-size: 16;" />

      <HBox alignment="CENTER" spacing="15">
        <Button fx:id="nextMissionButton" style="-fx-font-size: 14;" text="Next Mission" />

        <Button fx:id="retryButton" style="-fx-font-size: 14;" text="Retry Mission" />
      </HBox>

    </VBox>

  </StackPane>

</AnchorPane>
